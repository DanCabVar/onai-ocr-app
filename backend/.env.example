# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=onai_ocr

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRATION=7d

# Google Drive OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_root_folder_id

# AI Services
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_VISION_MODEL=pixtral-12b-latest
GOOGLE_AI_API_KEY=your_google_ai_api_key
GEMINI_MODEL=gemini-2.5-flash
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# Document Processing
MAX_FILE_SIZE=10485760
OTHERS_FOLDER_NAME=Otros Documentos
OTHERS_FOLDER_DESCRIPTION=Documentos no clasificados

# External Services
N8N_WEBHOOK_RAG=http://localhost:5678/webhook/rag
PROCESSOR_URL=http://processor:8000

# Stripe — Billing & Subscriptions
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Price IDs from Stripe Dashboard > Products > Prices
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
